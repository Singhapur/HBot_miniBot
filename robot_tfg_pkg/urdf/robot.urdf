<?xml version="1.0"?>
<robot name="mi_robot_tfg">

  <link name="base_link" />

  <link name="tf_luna_link" />
  <joint name="joint_laser" type="fixed">
    <parent link="base_link"/>
    <child link="tf_luna_link"/>
    <origin xyz="-0.05 0.0 0.00" rpy="0 0 0"/>
  </joint>

  <link name="imu_link" />
  <joint name="joint_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.00" rpy="0 0 0"/>
  </joint>

</robot>
